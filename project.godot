; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Finquest-v2"
run/main_scene="uid://b8iijuwlaxvhc"
config/quit_on_go_back=false
config/features=PackedStringArray("4.5", "GL Compatibility")
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

TransitionManager="*res://Scenes/transition_manager.tscn"
Global="*res://GD Scripts/Currency/global.gd"
DatabaseManager="*res://Managers/DatabaseManager.gd"
GameManager="*res://Managers/GameManager.gd"
SaveManager="*res://Managers/SaveManager.gd"
AchievementSystem="*res://Systems/AchievementSystem.gd"
ChapterSystem="*res://Systems/ChapterSystem.gd"
EconomySystem="*res://Systems/EconomySystem.gd"
EndingSystem="*res://Systems/EndingSystem.gd"
MinigameSystem="*res://Systems/MinigameSystem.gd"
AudioManager="*res://Managers/AudioManager.gd"

[display]

window/size/viewport_width=90
window/size/viewport_height=160
window/size/window_width_override=360
window/size/window_height_override=640
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/godot-sqlite/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/Backgrounds/": "orange",
"res://Assets/Buttons/": "green",
"res://Assets/Characters/": "red",
"res://Assets/Dialogue Box/": "yellow",
"res://GD Scripts/Characters/": "red",
"res://Scenes/": "yellow",
"res://Scenes/Characters/": "red"
}

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
